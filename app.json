{
  "expo": {
    "name": "GymCoach",
    "slug": "gym-coach",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gymcoach.app"
    },
    "android": {
      "package": "com.gymcoach.app",
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A"
      }
    },
    "plugins": ["expo-router"],
    "scheme": "gymcoach",
    "web": {
      "bundler": "metro",
      "output": "static"
    }
  }
}
